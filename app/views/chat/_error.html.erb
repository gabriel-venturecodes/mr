<div class="max-w-3xl mx-auto">
  <div class="flex items-start space-x-4">
    <div class="w-8 h-8 bg-red-600 rounded-lg flex items-center justify-center flex-shrink-0">
      <span class="text-white font-bold text-sm">!</span>
    </div>
    <div class="flex-1">
      <div class="bg-red-900 border border-red-700 rounded-lg p-4">
        <p class="text-red-200 font-medium mb-2">Analysis Failed</p>
        <p class="text-red-300 text-sm"><%= error %></p>
        
        <div class="mt-4">
          <%= link_to chat_path, 
              class: "inline-flex items-center px-3 py-2 bg-red-700 hover:bg-red-600 text-white text-sm rounded transition-colors" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
            Try Again
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
