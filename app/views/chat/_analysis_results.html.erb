<div class="max-w-4xl mx-auto space-y-6">
  
  <!-- User Message -->
  <% if local_assigns[:brief] %>
    <div class="flex items-start space-x-4 justify-end">
      <div class="flex-1 max-w-3xl">
        <div class="bg-green-600 rounded-lg p-4 ml-12">
          <p class="text-white"><%= local_assigns[:brief] %></p>
        </div>
      </div>
      <div class="w-8 h-8 bg-gray-600 rounded-full flex items-center justify-center flex-shrink-0">
        <span class="text-white text-sm">U</span>
      </div>
    </div>
  <% end %>

  <!-- Analysis Summary Header -->
  <div class="flex items-start space-x-4">
    <div class="w-8 h-8 flex items-center justify-center flex-shrink-0">
      <%= image_tag "mr-icon.png", alt: "MR Assistant", class: "w-8 h-8 object-contain rounded-lg" %>
    </div>
    <div class="flex-1">
      <div class="bg-gray-800 rounded-lg p-6">
        <div class="mb-6">
          <h3 class="text-lg font-semibold text-white mb-3">🎯 Analysis Complete</h3>
          <p class="text-gray-200 leading-relaxed">
            I've analyzed your research brief and generated <%= pluralize(hypotheses.count, 'insight') %> 
            with supporting evidence from your documents. Each insight includes specific citations 
            and confidence levels based on the available data.
          </p>
        </div>

        <!-- Nested Insights -->
        <div class="space-y-4">
          <% hypotheses.each_with_index do |hypothesis, index| %>
            <div class="bg-gray-900 rounded-lg border border-gray-700 overflow-hidden">
              <div class="flex min-h-full">
                <!-- Content Area -->
                <div class="flex-1 p-4">
                  <div class="flex items-start space-x-3">
                    <!-- Insight Number -->
                    <div class="w-8 h-8 bg-gradient-to-br from-blue-600 to-purple-600 rounded-full flex items-center justify-center flex-shrink-0">
                      <span class="text-white font-bold text-sm"><%= index + 1 %></span>
                    </div>
                    
                    <!-- Insight Content -->
                    <div class="flex-1">
                      <h4 class="text-lg font-semibold text-white mb-2">
                        <%= hypothesis.title %>
                      </h4>
                      <p class="text-gray-300 leading-relaxed mb-3">
                        <%= hypothesis.summary %>
                      </p>
                      
                      <!-- Insight Meta -->
                      <div class="flex items-center space-x-4 text-sm">
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs 
                          <%= hypothesis.status == 'verified' ? 'bg-green-900 text-green-200' : 
                              hypothesis.status == 'needs_evidence' ? 'bg-yellow-900 text-yellow-200' : 
                              'bg-red-900 text-red-200' %>">
                          <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                          </svg>
                          <%= hypothesis.status.humanize %>
                        </span>
                        <span class="text-gray-400">
                          <%= pluralize(hypothesis.claims.count, 'supporting claim') %>
                        </span>
                        <% if hypothesis.claims.verified.any? %>
                          <% max_similarity = hypothesis.claims.verified.map(&:max_citation_similarity).compact.max %>
                          <% if max_similarity %>
                            <span class="text-gray-400">
                              Verified by source chunks (max similarity <%= "#{(max_similarity * 100).round(1)}%" %> from 1 document)
                            </span>
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
                
                <!-- Full Height Arrow Button -->
                <%= form_with url: select_insight_path, method: :post, local: false do |form| %>
                  <%= form.hidden_field :hypothesis_id, value: hypothesis.id %>
                  <button type="submit" class="w-12 bg-gray-800 hover:bg-gray-700 flex items-center justify-center transition-colors group min-h-full">
                    <svg class="w-6 h-6 text-gray-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Audit Trail -->
        <% if local_assigns[:analysis] && hypotheses.first&.audit_trail.present? %>
          <div class="border-t border-gray-700 pt-6 mt-6">
            <%= render 'chat/audit_trail', hypothesis: hypotheses.first %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

</div>
