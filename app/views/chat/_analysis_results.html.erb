<div class="max-w-4xl mx-auto space-y-6">
  
  <!-- User Message -->
  <% if local_assigns[:brief] %>
    <div class="flex items-start space-x-4 justify-end">
      <div class="flex-1 max-w-3xl">
        <div class="bg-green-600 rounded-lg p-4 ml-12">
          <p class="text-white"><%= brief %></p>
        </div>
      </div>
      <div class="w-8 h-8 bg-gray-600 rounded-full flex items-center justify-center flex-shrink-0">
        <span class="text-white text-sm">U</span>
      </div>
    </div>
  <% end %>

  <!-- AI Response -->
  <div class="flex items-start space-x-4">
    <div class="w-8 h-8 flex items-center justify-center flex-shrink-0">
      <%= image_tag "mr-icon.png", alt: "MR Assistant", class: "w-8 h-8 object-contain rounded-lg" %>
    </div>
    <div class="flex-1">
      <div class="bg-gray-800 rounded-lg p-6">
        
        <!-- Summary -->
        <div class="mb-6">
          <h3 class="text-lg font-semibold text-white mb-3">Analysis Summary</h3>
          <p class="text-gray-200 leading-relaxed">
            I've analyzed your research brief and generated <%= pluralize(hypotheses.count, 'insight') %> 
            with supporting evidence from your documents. Each insight includes specific citations 
            and confidence levels based on the available data.
          </p>
        </div>

        <!-- How This Works - Expandable -->
        <div class="mb-6 bg-blue-900 bg-opacity-20 border border-blue-600 rounded-lg" data-controller="collapsible">
          <button class="w-full p-4 text-left flex items-center justify-between hover:bg-blue-900 hover:bg-opacity-30 transition-colors rounded-lg" data-action="click->collapsible#toggle">
            <div class="flex items-center">
              <svg class="w-5 h-5 mr-2 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="text-blue-200 font-medium">How this analysis works</span>
            </div>
            <svg class="w-4 h-4 text-blue-400 transform transition-transform" data-collapsible-target="arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          
          <div class="hidden px-4 pb-4 text-sm text-blue-100" data-collapsible-target="content">
            <div class="space-y-3">
              <div>
                <strong class="text-blue-200">📄 Chunks:</strong> Your documents are automatically split into "chunks" - sections of 2-3 paragraphs each. This allows us to precisely identify which specific parts of your documents support each claim, rather than just citing entire documents.
              </div>
              <div>
                <strong class="text-blue-200">📊 Similarity:</strong> We measure how closely our AI-generated insights match the actual text in your documents using semantic similarity (not just word matching). Higher percentages mean stronger evidence. Our threshold is 5% - claims above this are marked as verified.
              </div>
              <div>
                <strong class="text-blue-200">🧠 AI Analysis:</strong> We extract key entities, relationships, and generate hypotheses based on your research question.
              </div>
              <div>
                <strong class="text-blue-200">✅ Evidence Validation:</strong> Each claim is validated by measuring how well it's supported by your source material. Only claims with sufficient evidence support become verified insights.
              </div>
            </div>
          </div>
        </div>

        <!-- Hypotheses -->
        <% hypotheses.each_with_index do |hypothesis, index| %>
          <div class="mb-8 last:mb-0">
            <div class="flex items-start space-x-3 mb-4">
              <div class="w-6 h-6 bg-green-600 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <span class="text-white text-xs font-bold"><%= index + 1 %></span>
              </div>
              <div class="flex-1">
                <h4 class="text-lg font-semibold text-white mb-2"><%= hypothesis.title %></h4>
                <p class="text-gray-200 leading-relaxed mb-4"><%= hypothesis.summary %></p>
                
                <div class="flex items-center space-x-4 mb-4">
                  <div class="flex items-center">
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm 
                      <%= hypothesis.status == 'verified' ? 'bg-green-900 text-green-200' : 
                          hypothesis.status == 'needs_evidence' ? 'bg-yellow-900 text-yellow-200' : 
                          'bg-red-900 text-red-200' %>">
                      <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                      </svg>
                      <%= hypothesis.status.humanize %>
                    </span>
                  </div>
                  
                  <span class="text-sm text-gray-400">
                    <%= pluralize(hypothesis.claims.count, 'supporting claim') %>
                  </span>
                </div>
              </div>
            </div>

            <!-- Claims -->
            <div class="ml-9 space-y-4">
              <% hypothesis.claims.each do |claim| %>
                <div class="bg-gray-900 rounded-lg p-4 border-l-4 border-gray-600">
                  <div class="flex items-start justify-between mb-2">
                    <p class="text-gray-200 flex-1"><%= claim.text %></p>
                    <% if claim.explanation.present? %>
                      <span class="ml-3 px-2 py-1 bg-blue-700 text-blue-200 text-xs rounded">
                        <%= claim.status.humanize %>
                      </span>
                    <% end %>
                  </div>
                  
                  <% if claim.explanation.present? %>
                    <div class="mt-3 p-3 bg-gray-800 rounded border-l-2 border-blue-400">
                      <p class="text-sm text-gray-300 italic"><%= claim.explanation %></p>
                      <% if claim.citation_chunk_ids.present? %>
                        <div class="mt-2">
                          <div class="flex items-center mb-1">
                            <span class="text-xs font-medium text-gray-400 uppercase tracking-wide">Evidence Sources:</span>
                          </div>
                          <div class="flex flex-wrap gap-1">
                            <% 
                              # Group chunks by document to avoid duplicates
                              chunks_by_doc = claim.cited_chunks.includes(:document).group_by(&:document)
                              chunks_by_doc.each do |document, chunks|
                            %>
                              <span class="inline-flex items-center px-2 py-1 rounded text-xs bg-blue-900 text-blue-200">
                                <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                  <path d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z"/>
                                </svg>
                                <%= document&.title || 'Document' %>
                                <% if chunks.count > 1 %>
                                  <span class="ml-1 text-xs opacity-75">(#{chunks.count} sections)</span>
                                <% end %>
                              </span>
                            <% end %>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Audit Trail -->
        <% if hypotheses.first&.audit_trail.present? %>
          <%= render 'chat/audit_trail', hypothesis: hypotheses.first %>
        <% end %>

        <!-- Action Buttons -->
        <div class="mt-8 pt-6 border-t border-gray-700">
          <div class="flex flex-wrap gap-3">
            <!-- <%= link_to chat_path, 
                class: "inline-flex items-center px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg transition-colors" do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
              </svg>
              New Analysis
            <% end %>
             -->
            <button class="inline-flex items-center px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition-colors">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
              Export Report
            </button>
            
            <button class="inline-flex items-center px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition-colors">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z"/>
              </svg>
              Share Results
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Insight Selection or Continue Conversation -->
  <% if hypotheses.count > 1 %>
    <%= render 'chat/insight_selection', hypotheses: hypotheses, analysis: analysis %>
  <% else %>
    <!-- Continue Conversation -->
    <div class="flex items-start space-x-4">
      <div class="w-8 h-8 flex items-center justify-center flex-shrink-0">
        <%= image_tag "mr-icon.png", alt: "MR Assistant", class: "w-8 h-8 object-contain rounded-lg" %>
      </div>
      <div class="flex-1">
        <div class="bg-gray-800 rounded-lg p-4">
          <p class="text-gray-200 mb-3">What would you like to explore next?</p>
          <div class="space-y-2">
            <button class="block w-full text-left px-3 py-2 bg-gray-700 hover:bg-gray-600 rounded text-sm text-gray-200 transition-colors"
                    data-action="click->example-questions#fillQuestion">
              "Dive deeper into this insight"
            </button>
            <button class="block w-full text-left px-3 py-2 bg-gray-700 hover:bg-gray-600 rounded text-sm text-gray-200 transition-colors"
                    data-action="click->example-questions#fillQuestion">
              "Show me the original source quotes"
            </button>
            <button class="block w-full text-left px-3 py-2 bg-gray-700 hover:bg-gray-600 rounded text-sm text-gray-200 transition-colors"
                    data-action="click->example-questions#fillQuestion">
              "Generate actionable recommendations"
            </button>
          </div>
        </div>
      </div>
    </div>
  <% end %>

</div>
