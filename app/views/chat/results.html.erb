<div class="flex h-screen bg-chat-bg">
  <!-- Sidebar (like ChatGPT) -->
  <div class="w-64 bg-chat-sidebar border-r border-chat-border flex flex-col">
    <!-- Header -->
    <div class="p-4 border-b border-chat-border">
      <div class="flex items-center space-x-3">
        <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
          <span class="text-white font-bold text-sm">MR</span>
        </div>
        <span class="text-white font-semibold">Market Research</span>
      </div>
    </div>

    <!-- Back to Chat Button -->
    <div class="p-3">
      <%= link_to chat_path, class: "w-full bg-transparent border border-chat-border text-white px-4 py-2.5 rounded-lg hover:bg-gray-800 transition-colors flex items-center space-x-2" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        <span>New Analysis</span>
      <% end %>
    </div>

    <!-- Analysis History -->
    <div class="flex-1 px-3 overflow-y-auto">
      <div class="mb-4">
        <h3 class="text-gray-400 text-xs font-semibold uppercase tracking-wider mb-2">Current Analysis</h3>
        <div class="bg-gray-800 rounded p-2">
          <p class="text-sm text-white font-medium">Research Brief</p>
          <p class="text-xs text-gray-300 mt-1 line-clamp-3"><%= @brief %></p>
        </div>
      </div>
    </div>

    <!-- User Section -->
    <div class="p-3 border-t border-chat-border">
      <div class="flex items-center space-x-3">
        <div class="w-8 h-8 bg-gray-600 rounded-full flex items-center justify-center">
          <span class="text-white text-sm">U</span>
        </div>
        <span class="text-gray-300 text-sm">Demo User</span>
      </div>
    </div>
  </div>

  <!-- Main Chat Area -->
  <div class="flex-1 flex flex-col">
    <!-- Chat Header -->
    <div class="p-4 border-b border-chat-border">
      <h1 class="text-xl font-semibold text-white">Analysis Results</h1>
      <p class="text-gray-400 text-sm">AI-generated insights with citations and evidence</p>
    </div>

    <!-- Chat Messages Area -->
    <div class="flex-1 overflow-y-auto p-4">
      <%= turbo_frame_tag "chat-messages", class: "h-full" do %>
        <%= render partial: "chat/analysis_results", locals: { brief: @brief, hypotheses: @hypotheses, analysis_result: @analysis_result } %>
      <% end %>
    </div>

    <!-- Input Area -->
    <div class="p-4 border-t border-chat-border">
      <div class="max-w-4xl mx-auto">
        <%= form_with url: analyze_path, method: :post, class: "relative", data: { turbo_frame: "chat-messages" } do |form| %>
          <div class="flex items-end space-x-3">
            <div class="flex-1">
              <%= form.text_area :brief, 
                  placeholder: "Ask a follow-up question...", 
                  rows: 1,
                  class: "w-full bg-chat-input border border-chat-border rounded-lg px-4 py-3 text-white placeholder-gray-400 resize-none focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent",
                  data: { 
                    controller: "textarea-resize form-submit",
                    action: "input->textarea-resize#resize keydown->form-submit#submit" 
                  } %>
            </div>
            <%= form.submit class: "bg-green-600 hover:bg-green-700 text-white p-3 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-green-500",
                data: { disable_with: "Analyzing..." } do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
