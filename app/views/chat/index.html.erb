<div class="flex bg-chat-bg" data-controller="example-questions documents-panel">
  <!-- Floating Left Sidebar -->
  <div class="absolute left-4 top-4 bottom-4 w-64 z-10">
    <div class="bg-chat-sidebar rounded-xl border border-chat-border flex flex-col h-full shadow-lg">
      <!-- Logo Section -->
      <div class="p-6 border-b border-chat-border">
        <div class="flex flex-col items-center space-y-4">
          <div class="w-32 h-32 flex items-center justify-center">
            <%= image_tag "mr-logo.png", alt: "MR Logo", class: "w-32 h-32 object-contain" %>
          </div>
          
          <!-- New Analysis Button (always visible) -->
          <%= link_to chat_path, class: "w-full bg-green-600 hover:bg-green-700 text-white px-4 py-2.5 rounded-lg transition-colors flex items-center justify-center space-x-2" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            <span>New Analysis</span>
          <% end %>
        </div>
      </div>

      <!-- Recent Analyses -->
      <div class="flex-1 px-4 py-4 overflow-y-auto">
        <div>
          <h3 class="text-gray-400 text-xs font-semibold uppercase tracking-wider mb-3">Recent Analyses</h3>
          <% if @recent_hypotheses.any? %>
            <div class="space-y-2">
              <% @recent_hypotheses.each do |hypothesis| %>
                <div class="group relative">
                  <%= link_to hypothesis_path(hypothesis), class: "block p-3 rounded-lg hover:bg-gray-800 transition-colors #{'bg-gray-800' if @hypotheses && @hypotheses.include?(hypothesis)}" do %>
                    <p class="text-sm text-gray-300 line-clamp-2 leading-relaxed pr-6"><%= hypothesis.title %></p>
                    <span class="text-xs text-green-400 mt-1 inline-block">✓ Verified</span>
                  <% end %>
                  
                  <!-- Delete button -->
                  <%= link_to hypothesis_path(hypothesis), 
                      method: :delete, 
                      class: "absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity bg-red-600 hover:bg-red-700 text-white p-1 rounded text-xs",
                      title: "Delete analysis and documents",
                      data: { 
                        confirm: "Are you sure? This will delete the analysis and all associated documents.",
                        turbo_method: :delete 
                      } do %>
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-500 text-sm">No analyses yet</p>
          <% end %>
        </div>
      </div>

      <!-- User Section at Bottom -->
      <div class="p-3 border-t border-chat-border">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-3">
            <div class="w-8 h-8 bg-gray-600 rounded-full flex items-center justify-center">
              <span class="text-white text-sm"><%= current_user.email[0].upcase %></span>
            </div>
            <span class="text-gray-300 text-sm"><%= current_user.email.split('@').first %></span>
          </div>
          <%= link_to destroy_user_session_path, method: :delete, 
              class: "text-gray-400 hover:text-gray-300 p-1 rounded transition-colors",
              title: "Sign out" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013 3v1"/>
            </svg>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Chat Area -->
  <div class="flex-1 flex flex-col ml-72">
    <!-- Chat Messages Area with floating content -->
    <div class="flex-1 overflow-y-auto p-4">
      <%= turbo_frame_tag "chat-messages", class: "h-full" do %>
        <% if @hypotheses && @hypotheses.any? %>
          <!-- Combined Title and Analysis in Single Floating Card -->
          <div class="max-w-4xl mx-auto">
            <div class="bg-chat-sidebar rounded-xl border border-chat-border p-6 shadow-lg mb-6">
              <div class="flex items-start justify-between mb-4">
                <h1 class="text-2xl font-semibold text-white"><%= @hypotheses.first.title %></h1>
                <button class="text-blue-400 text-sm hover:underline ml-4 flex-shrink-0" 
                        data-action="click->documents-panel#toggle">
                  See documents
                </button>
              </div>
              
              <!-- Analysis Results -->
              <%= render 'chat/analysis_results', hypotheses: @hypotheses, brief: @brief %>
            </div>
          </div>
        <% else %>
          <!-- Welcome Message -->
          <div class="max-w-3xl mx-auto mb-8">
            <div class="flex items-start space-x-4">
              <div class="w-8 h-8 flex items-center justify-center flex-shrink-0">
                <%= image_tag "mr-icon.png", alt: "MR Assistant", class: "w-8 h-8 object-contain rounded-lg" %>
              </div>
              <div class="flex-1">
                <div class="bg-gray-800 rounded-lg p-6">
                  <div class="mb-4">
                    <h2 class="text-white text-lg font-semibold mb-2">Welcome to Market Research AI!</h2>
                    <p class="text-gray-300">
                      I can help you analyze documents and generate insights with full citations. Here's how it works:
                    </p>
                  </div>
                  
                  <div class="space-y-3 mb-6">
                    <div class="flex items-start space-x-3">
                      <div class="w-6 h-6 bg-green-600 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                        <span class="text-white text-xs font-bold">1</span>
                      </div>
                      <div>
                        <p class="text-white text-sm font-medium">Upload your documents</p>
                        <p class="text-gray-400 text-sm">Click the + button to attach PDF, CSV, TXT, or JSON files containing your research data</p>
                      </div>
                    </div>
                    
                    <div class="flex items-start space-x-3">
                      <div class="w-6 h-6 bg-green-600 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                        <span class="text-white text-xs font-bold">2</span>
                      </div>
                      <div>
                        <p class="text-white text-sm font-medium">Ask your research question</p>
                        <p class="text-gray-400 text-sm">Type specific questions about your data or request insights and analysis</p>
                      </div>
                    </div>
                    
                    <div class="flex items-start space-x-3">
                      <div class="w-6 h-6 bg-green-600 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                        <span class="text-white text-xs font-bold">3</span>
                      </div>
                      <div>
                        <p class="text-white text-sm font-medium">Get AI-powered insights</p>
                        <p class="text-gray-400 text-sm">Receive detailed analysis with citations pointing to specific parts of your documents</p>
                      </div>
                    </div>
                  </div>
                  
                  <div class="border-t border-gray-700 pt-4">
                    <p class="text-gray-300 text-sm font-medium mb-2">Try asking:</p>
                    <div class="space-y-1">
                      <button class="block w-full text-left px-3 py-2 bg-gray-700 hover:bg-gray-600 rounded text-sm text-gray-200 transition-colors"
                              data-action="click->example-questions#fillQuestion">
                        "How do young consumers perceive eco-friendly packaging?"
                      </button>
                      <button class="block w-full text-left px-3 py-2 bg-gray-700 hover:bg-gray-600 rounded text-sm text-gray-200 transition-colors"
                              data-action="click->example-questions#fillQuestion">
                        "What are the main concerns about oat milk in coffee?"
                      </button>
                      <button class="block w-full text-left px-3 py-2 bg-gray-700 hover:bg-gray-600 rounded text-sm text-gray-200 transition-colors"
                              data-action="click->example-questions#fillQuestion">
                        "Identify opportunities for sustainability messaging"
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- Chat Input -->
    <div class="p-4">
      <div class="max-w-3xl mx-auto">
        <div id="attachment-menu" data-controller="attachment-menu chat-form" data-chat-form-attachment-menu-outlet="#attachment-menu">
          <%= form_with url: analyze_path, method: :post, multipart: true, class: "relative", data: { turbo_frame: "chat-messages", chat_form_target: "form" } do |form| %>
            <div class="chat-input-container flex items-center space-x-3 p-3">
              <!-- Plus button for attachments -->
              <div class="relative">
                <button type="button" 
                        class="bg-transparent hover:bg-gray-600 text-gray-400 hover:text-white p-1.5 rounded-lg transition-colors focus:outline-none"
                        data-action="click->attachment-menu#toggle">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                  </svg>
                </button>
                
                <!-- Attachment menu -->
                <div class="absolute bottom-full left-0 mb-2 w-64 bg-chat-input border border-chat-border rounded-lg shadow-lg hidden"
                     data-attachment-menu-target="menu">
                  <div class="p-3">
                    <div class="mb-3">
                      <h3 class="text-white text-sm font-medium mb-1">Attach Files</h3>
                      <p class="text-gray-400 text-xs">Supported formats: PDF, CSV, TXT, JSON</p>
                    </div>
                    <label class="flex items-center space-x-3 p-2 hover:bg-gray-700 rounded cursor-pointer transition-colors">
                      <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
                      </svg>
                      <span class="text-white text-sm">Choose Files</span>
                      <%= form.file_field :documents, multiple: true, accept: ".csv,.json,.pdf,.txt", class: "sr-only", data: { action: "change->attachment-menu#filesSelected" } %>
                    </label>
                  </div>
                </div>
              </div>

            <!-- Text input area -->
            <div class="flex-1 flex items-center">
              <%= form.text_area :brief, 
                  placeholder: "Enter your research question...", 
                  rows: 1,
                  class: "w-full bg-transparent border-none text-white placeholder-gray-400 resize-none focus:outline-none overflow-hidden leading-6 py-1",
                  data: { 
                    controller: "textarea-resize form-submit",
                    action: "input->textarea-resize#resize keydown->form-submit#submit",
                    chat_form_target: "textInput"
                  } %>
            </div>

            <!-- Send button (arrow) -->
            <button type="submit" 
                    class="bg-green-600 hover:bg-green-700 text-white p-2 rounded-lg transition-colors focus:outline-none disabled:opacity-50 flex-shrink-0"
                    data-disable-with="...">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
            </button>
          </div>

          <!-- Selected files indicator -->
          <div class="hidden mt-3" data-attachment-menu-target="selectedFiles">
            <div class="bg-gray-700 border border-gray-600 rounded-lg p-3">
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center space-x-2">
                  <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span class="text-sm text-white font-medium">Files attached:</span>
                </div>
                <button type="button" 
                        class="text-gray-400 hover:text-red-400 text-sm transition-colors"
                        data-action="click->attachment-menu#clearFiles">
                  Remove all
                </button>
              </div>
              <div data-attachment-menu-target="fileList" class="space-y-2"></div>
            </div>
          </div>
        <% end %>
        
        <p class="text-gray-500 text-xs mt-2 text-center">
          MR can make mistakes. Check important info and verify citations.
        </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Documents Modal (Right Side) -->
  <div class="fixed right-4 top-4 bottom-4 w-96 z-30 hidden" 
       data-documents-panel-target="panel">
    <div class="bg-chat-sidebar rounded-xl border border-chat-border flex flex-col h-full shadow-2xl">
      <!-- Modal Header -->
      <div class="p-4 border-b border-chat-border flex items-center justify-between">
        <div class="flex items-center space-x-2">
          <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
          <h3 class="text-white font-semibold">Documents</h3>
        </div>
        <button class="text-gray-400 hover:text-white transition-colors p-1 rounded hover:bg-gray-700"
                data-action="click->documents-panel#close"
                title="Close documents panel">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Documents List -->
      <div class="flex-1 overflow-y-auto p-4">
        <% if @documents.any? %>
          <div class="space-y-3">
            <% @documents.each do |doc| %>
              <div class="bg-gray-800 rounded-lg p-4 border border-gray-700 hover:border-gray-600 transition-colors">
                <div class="flex items-start justify-between mb-3">
                  <div class="flex items-start space-x-3">
                    <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center flex-shrink-0">
                      <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                      </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <h4 class="text-sm font-medium text-white line-clamp-2 break-words"><%= doc.title %></h4>
                      <p class="text-xs text-gray-400 mt-1">
                        <%= pluralize(doc.chunks.count, 'chunk') %> • 
                        Uploaded <%= time_ago_in_words(doc.created_at) %> ago
                      </p>
                    </div>
                  </div>
                  <span class="ml-2 px-2 py-1 text-xs rounded font-medium flex-shrink-0
                    <%= doc.completed? ? 'bg-green-600 text-white' : 'bg-yellow-600 text-white' %>">
                    <%= doc.completed? ? 'Ready' : 'Processing' %>
                  </span>
                </div>
                
                <% if doc.chunks.any? %>
                  <div class="bg-gray-900 rounded p-2 mt-2">
                    <p class="text-xs text-gray-400 mb-1">Sample content:</p>
                    <p class="text-xs text-gray-300 line-clamp-2">
                      <%= truncate(doc.chunks.first.text, length: 100) %>
                    </p>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center text-gray-500 mt-8">
            <div class="w-16 h-16 bg-gray-800 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
              </svg>
            </div>
            <h4 class="text-white text-sm font-medium mb-2">No documents uploaded</h4>
            <p class="text-xs text-gray-400">Upload documents using the + button to start analyzing</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
