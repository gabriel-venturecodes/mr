<% if resource.errors.any? %>
  <div class="bg-red-900 border border-red-700 rounded-lg p-4 mb-4">
    <div class="flex items-center">
      <svg class="w-5 h-5 text-red-400 mr-2" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
      </svg>
      <h3 class="text-red-200 font-medium">
        <%= pluralize(resource.errors.count, "error") %> prohibited this <%= resource.class.model_name.human.downcase %> from being saved:
      </h3>
    </div>
    
    <ul class="mt-2 text-red-300 text-sm space-y-1">
      <% resource.errors.full_messages.each do |message| %>
        <li class="flex items-center">
          <span class="w-1 h-1 bg-red-400 rounded-full mr-2"></span>
          <%= message %>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>
